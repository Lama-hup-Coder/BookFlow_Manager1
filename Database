CREATE VIEW [dbo].[v_Applications_List] AS
SELECT 
    Applications.ApplicationID, 
    Applications.ApplicantPersonID, 
    -- استخدام اسم العمود الصحيح من جدول People
    People.FullName, 
    Applications.ApplicationDate, 
    Applications.ApplicationTypeID, 
    ApplicationTypes.ApplicationTypeTitle,
    -- تحويل الحالة من رقم إلى نص مفهوم (Readable Status)
    CASE 
        WHEN Applications.ApplicationStatus = 1 THEN 'New'
        WHEN Applications.ApplicationStatus = 2 THEN 'Cancelled'
        WHEN Applications.ApplicationStatus = 3 THEN 'Completed'
        ELSE 'Unknown'
    END AS StatusName,
    Applications.PaidFees, 
    Applications.CreatedByUserID
FROM Applications 
INNER JOIN People ON Applications.ApplicantPersonID = People.PersonID
INNER JOIN ApplicationTypes ON Applications.ApplicationTypeID = ApplicationTypes.ApplicationTypeID;
