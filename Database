CREATE VIEW [dbo].[v_BorrowingRecordsDetails] AS
SELECT 
    B.BorrowID, 
    B.ApplicationID,
    -- سحب اسم العضو من جدول People مباشرة عبر الربط مع Applications
    P.FullName AS MemberName, 
    M.LibraryCardNumber,
    B.BookID,
    BK.Title AS BookTitle, 
    B.DueDate, 
    B.ActualReturnDate,
    -- حالة الكتاب: مسترجع، متأخر، أو قيد الاستعارة
    CASE 
        WHEN B.ActualReturnDate IS NOT NULL THEN 'Returned'
        WHEN CAST(GETDATE() AS DATE) > B.DueDate THEN 'Overdue'
        ELSE 'Ongoing'
    END AS Status,
    -- حساب الغرامة بناءً على فئة الكتاب (BookCategories)
    CASE 
        WHEN B.ActualReturnDate IS NULL AND CAST(GETDATE() AS DATE) > B.DueDate 
        THEN DATEDIFF(day, B.DueDate, GETDATE()) * BC.LateFeePerDay
        ELSE 0
    END AS CurrentFine
FROM BorrowingRecords B
INNER JOIN Books BK ON B.BookID = BK.BookID
INNER JOIN BookCategories BC ON BK.CategoryID = BC.CategoryID
INNER JOIN Applications A ON B.ApplicationID = A.ApplicationID
INNER JOIN People P ON A.ApplicantPersonID = P.PersonID -- تأكدي من هذا الاسم في جدول Applications
INNER JOIN Members M ON P.PersonID = M.PersonID; -- الربط مع جدول الأعضاء (بدون ديسكريبشن)
